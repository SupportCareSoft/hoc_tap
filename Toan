<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Toán Học 4 Hàng - Thông Báo Sai</title>
    <style>
        :root {
            --bg: #f0f4f8;
            --box-num: #FFD54F; /* Vàng tươi */
            --correct: #4CAF50;
            --wrong: #F44336;
            --text: #2c3e50;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
        }

        .header { margin-bottom: 20px; text-align: center; }

        .math-container {
            display: flex;
            flex-direction: column;
            gap: 30px;
            width: 100%;
            max-width: 1200px;
        }

        .math-row {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 15px;
        }

        .math-card {
            background: white;
            padding: 20px 10px;
            border-radius: 20px;
            display: flex;
            flex-direction: column; /* Để thông báo nằm dưới phép tính */
            align-items: center;
            box-shadow: 0 8px 16px rgba(0,0,0,0.05);
            transition: transform 0.2s;
        }

        .equation {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .num {
            font-size: 24px;
            font-weight: 900;
            background: var(--box-num);
            padding: 5px 12px;
            border-radius: 10px;
            min-width: 35px;
            text-align: center;
        }

        .op { font-size: 22px; font-weight: bold; color: #555; }

        .ans-input {
            width: 60px;
            height: 50px;
            border: 3px solid #ddd;
            border-radius: 12px;
            text-align: center;
            font-size: 22px;
            font-weight: 900;
            outline: none;
            transition: all 0.3s;
        }

        /* Thông báo lỗi */
        .error-msg {
            font-size: 12px;
            color: var(--wrong);
            margin-top: 8px;
            font-weight: bold;
            height: 15px; /* Giữ vị trí cố định */
            visibility: hidden;
        }

        /* Trạng thái đúng/sai */
        .ans-input.correct { border-color: var(--correct); background-color: #e8f5e9; }
        .ans-input.wrong { border-color: var(--wrong); background-color: #ffebee; animation: shake 0.3s; }
        .ans-input.wrong + .error-msg { visibility: visible; }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        .btn-group { margin-top: 30px; display: flex; gap: 15px; }
        button, select {
            padding: 12px 25px; border-radius: 12px; border: none;
            font-weight: bold; cursor: pointer; font-size: 16px;
        }
        .btn-refresh { background: #2196F3; color: white; }
        .btn-check { background: var(--correct); color: white; }

        @media (max-width: 1000px) {
            .math-row { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>

    <div class="header">
        <h1 style="color: var(--text);">Thử Thách 20 Phép Tính</h1>
        <select id="level" onchange="generateMath()">
            <option value="5">Bé 5 tuổi (Dễ)</option>
            <option value="7">Lớp 1 (Nâng cao)</option>
        </select>
    </div>

    <div class="math-container" id="container"></div>

    <div class="btn-group">
        <button class="btn-refresh" onclick="generateMath()">🔄 Đổi bài mới</button>
        <button class="btn-check" onclick="checkResults()">✅ Kiểm tra bài</button>
    </div>

    <script>
        function generateMath() {
            const level = document.getElementById('level').value;
            const container = document.getElementById('container');
            container.innerHTML = "";

            for (let r = 0; r < 4; r++) {
                const rowDiv = document.createElement('div');
                rowDiv.className = 'math-row';

                for (let c = 0; c < 5; c++) {
                    let n1, n2, op;
                    if (level === "5") {
                        n1 = Math.floor(Math.random() * 9) + 1;
                        n2 = Math.floor(Math.random() * 9) + 1;
                    } else {
                        n1 = Math.floor(Math.random() * 50) + 10;
                        n2 = Math.floor(Math.random() * 40) + 5;
                    }
                    
                    op = (n1 >= n2 && Math.random() > 0.5) ? '-' : '+';
                    const result = (op === '+') ? n1 + n2 : n1 - n2;

                    rowDiv.innerHTML += `
                        <div class="math-card">
                            <div class="equation">
                                <span class="num">${n1}</span>
                                <span class="op">${op}</span>
                                <span class="num">${n2}</span>
                                <span class="op">=</span>
                                <input type="number" class="ans-input" data-ans="${result}">
                            </div>
                            <div class="error-msg">Sai rồi, tính lại nhé! ❌</div>
                        </div>
                    `;
                }
                container.appendChild(rowDiv);
            }
        }

        function checkResults() {
            document.querySelectorAll('.ans-input').forEach(input => {
                const val = input.value;
                const ans = input.dataset.ans;
                
                if (val === "") {
                    input.classList.remove('correct', 'wrong');
                } else if (parseInt(val) === parseInt(ans)) {
                    input.classList.remove('wrong');
                    input.classList.add('correct');
                } else {
                    input.classList.remove('correct');
                    input.classList.add('wrong');
                }
            });
        }

        window.onload = generateMath;
    </script>
</body>
</html>
